{
  "name": "react_electron_app",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de Aniversariantes UniATENEU",
  "author": {
    "name": "UniATENEU",
    "email": "kaueribeiro125@gmail.com"
  },
  "dependencies": {
    "@electron/rebuild": "^3.7.2",
    "@electron/remote": "^2.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@material-tailwind/react": "^2.1.10",
    "@mui/material": "^7.3.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-is-dev": "^2.0.0",
    "firebase": "^12.12.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "wait-on": "^9.0.4",
    "web-vitals": "^2.1.4"
  },
  "main": "public/main.js",
  "homepage": "./",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron:serve": "concurrently -k \"cross-env BROWSER=none yarn start\" \"yarn electron:start\"",
    "electron:build": "react-scripts build && electron-builder",
    "electron:build:dir": "react-scripts build && electron-builder --dir",
    "electron:start": "wait-on tcp:3000 && electron ."
  },
  "build": {
    "appId": "com.uniateneu.aniversariantes",
    "productName": "Aniversariantes UniATENEU",
    "extraMetadata": {
      "main": "build/main.js"
    },
    "files": [
      "build/**/*",
      "public/main.js",
      "public/preload.js",
      "public/logoUniAteneu.ico",
      "public/logo512_new.png",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "public/main.js",
        "to": "build/main.js"
      },
      {
        "from": "public/preload.js",
        "to": "build/preload.js"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/logo512_new.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logoUniAteneu.ico"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.4"
  }
}
